<table class="table">
  <thead>
    <tr>
      <th scope="col">Weather</th>
      <th scope="col">Temp<th>
      <th scope="col">Humidity</th>
    </tr>
  </thead>

  <tbody>  
    <tr>
      <td><%= @final_output['weather'][0]['main'] %></td>
      <td><%= @final_output['main']['temp'].to_i - 273 %></td>
      <td><%= @final_output['main']['humidity'] %></td>
    </tr>
  </tbody> 
</table>



<%= @final_output %>

<br>



<%= form_tag root_path, method: :get do %>
  <%= text_field_tag :query,
    params[:query],
    class: "form-control",
    placeholder: "Choose a city"
  %>
  <%= submit_tag "Search", class: "btn btn-primary" %>
<% end %>
